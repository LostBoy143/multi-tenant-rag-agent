PORT=8000
WEBSITES_PORT=8000

ENVIRONMENT=development
LOG_LEVEL=INFO
STARTUP_FAIL_FAST=false
STARTUP_CHECK_RETRIES=3
STARTUP_CHECK_INTERVAL_SECONDS=3
STARTUP_CHECK_TIMEOUT_SECONDS=10
RUN_MIGRATIONS_ON_STARTUP=false



DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/rag_saas

# Qdrant Settings (Uncomment either local OR cloud below)
# Qdrant Local
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Qdrant Cloud
QDRANT_URL=https://your-qdrant-cloud-url
QDRANT_API_KEY=your-qdrant-api-key

# AI Settings
GEMINI_API_KEY=your-gemini-api-key-here
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
LLM_MODEL=gemini-2.0-flash

# App Settings
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Authentication & Security
JWT_SECRET=your-random-secure-jwt-secret
ADMIN_SECRET=your-random-secure-admin-secret

# Super Admin Account
SUPERADMIN_EMAIL=admin@bolchat.ai
SUPERADMIN_PASSWORD=bolchat-admin-2026

# Redis Server (Local or Upstash)
REDIS_URL=redis://localhost:6379/0

# Email Settings
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-secret-smtp-password
SMTP_FROM=noreply@bolchat.ai
